"use client";

import { useState, useTransition } from "react";
import { useRouter } from "next/navigation";
import { updateExpenseCategory, deleteExpense } from "@/app/expenses/actions";

type Category = { id: string; name: string };

type Expense = {
  id: string;
  amount: number;
  expense_date: string;
  vendor_text: string | null;
  source: string;
  category_id: string | null;
  user_id: string;
  categories: { name: string } | null;
  profiles: { display_name: string | null } | null;
};

const money = new Intl.NumberFormat("en-IN", {
  style: "currency",
  currency: "INR",
  maximumFractionDigits: 0,
});

export function ExpensesTable({
  expenses,
  categories,
  currentUserId,
}: {
  expenses: Expense[];
  categories: Category[];
  currentUserId: string | null;
}) {
  const router = useRouter();
  const [isPending, startTransition] = useTransition();
  const [pendingId, setPendingId] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);

  function handleCategoryChange(id: string, newCategoryId: string) {
    setError(null);
    setPendingId(id);
    startTransition(async () => {
      const result = await updateExpenseCategory(id, newCategoryId);
      setPendingId(null);
      if (result?.error) {
        setError(result.error);
      } else {
        router.refresh();
      }
    });
  }

  function handleDelete(id: string) {
    if (!confirm("Delete this expense? This can't be undone.")) return;
    setError(null);
    setPendingId(id);
    startTransition(async () => {
      const result = await deleteExpense(id);
      setPendingId(null);
      if (result?.error) {
        setError(result.error);
      } else {
        router.refresh();
      }
    });
  }

  if (expenses.length === 0) {
    return <p className="text-sm text-ink-soft">No expenses match this filter.</p>;
  }

  return (
    <div>
      {error && (
        <p className="mb-3 rounded-sm bg-rust/10 px-3 py-2 text-sm text-rust" role="alert">
          {error}
        </p>
      )}
      <div className="overflow-hidden rounded-sm border border-line">
        <table className="w-full text-sm">
          <thead>
            <tr className="border-b border-line bg-paper-raised text-left text-xs uppercase tracking-wide text-ink-soft">
              <th className="px-3 py-2">Date</th>
              <th className="px-3 py-2">Vendor</th>
              <th className="px-3 py-2">Category</th>
              <th className="px-3 py-2">Paid by</th>
              <th className="px-3 py-2 text-right">Amount</th>
              <th className="px-3 py-2"></th>
            </tr>
          </thead>
          <tbody>
            {expenses.map((row) => {
              const isOwn = row.user_id === currentUserId;
              const rowPending = isPending && pendingId === row.id;
              return (
                <tr key={row.id} className="border-b border-line last:border-0">
                  <td className="whitespace-nowrap px-3 py-2 text-ink-soft">
                    {new Date(row.expense_date).toLocaleDateString("en-IN", {
                      day: "2-digit",
                      month: "short",
                      year: "2-digit",
                    })}
                  </td>
                  <td className="px-3 py-2 text-ink">{row.vendor_text ?? "—"}</td>
                  <td className="px-3 py-2">
                    {isOwn ? (
                      <select
                        value={row.category_id ?? ""}
                        disabled={rowPending}
                        onChange={(e) => handleCategoryChange(row.id, e.target.value)}
                        className="rounded-sm border border-line bg-paper px-1 py-1 text-xs text-ink disabled:opacity-50"
                      >
                        {categories.map((c) => (
                          <option key={c.id} value={c.id}>
                            {c.name}
                          </option>
                        ))}
                      </select>
                    ) : (
                      <span className="text-ink-soft">{row.categories?.name ?? "Uncategorized"}</span>
                    )}
                  </td>
                  <td className="px-3 py-2 text-ink-soft">{row.profiles?.display_name ?? "—"}</td>
                  <td className="px-3 py-2 text-right font-mono text-ink">{money.format(row.amount)}</td>
                  <td className="px-3 py-2 text-right">
                    {isOwn && (
                      <button
                        type="button"
                        onClick={() => handleDelete(row.id)}
                        disabled={rowPending}
                        className="text-xs text-ink-soft hover:text-rust disabled:opacity-50"
                      >
                        Delete
                      </button>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}
